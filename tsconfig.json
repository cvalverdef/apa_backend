{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "noImplicitAny": false,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "lib": ["es2022", "esnext", "dom"],
    "skipLibCheck": true,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "**/*.spec.ts",
    "**/*.e2e-spec.ts",
    "**/test/**/*",
    "**/*.test.ts"
  ]
}
