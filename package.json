{
  "name": "apa-byos-backend",
  "version": "1.0.0",
  "description": "Backend for APA BYOS application using NestJS",
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "NODE_ENV=production node --max-old-space-size=384 dist/main.js",
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "migration:run": "npm run build && npx typeorm migration:run -d dist/data-source.js",
    "migration:generate": "npx typeorm migration:generate -d src/data-source.ts",
    "migration:create": "npx typeorm migration:create",
    "migration:revert": "npx typeorm migration:revert -d dist/data-source.js",
    "migration:show": "npx typeorm migration:show -d dist/data-source.js"
  },
  "dependencies": {
    "@nestjs/axios": "^3.1.3",
    "@nestjs/common": "^9.0.0",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^9.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^9.4.3",
    "@nestjs/schedule": "^3.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^9.0.1",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.2",
    "multer": "^2.0.2",
    "nodemailer": "^6.10.1",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.26",
    "typescript": "^4.5.0",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^9.4.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^27.5.2",
    "@types/node": "^24.10.1",
    "@types/passport-jwt": "^3.0.0",
    "@types/uuid": "^10.0.0",
    "jest": "^27.0.0",
    "ts-jest": "^27.0.0",
    "ts-loader": "^9.0.0",
    "ts-node": "^10.9.2"
  },
  "keywords": [],
  "author": "",
  "license": "MIT"
}
